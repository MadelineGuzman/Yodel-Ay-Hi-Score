{"firstLayout":"SplashScreen","gdVersion":{"build":269,"major":5,"minor":6,"revision":0},"properties":{"adaptGameResolutionAtRuntime":false,"antialiasingMode":"MSAA","antialisingEnabledOnMobile":false,"folderProject":false,"orientation":"default","packageName":"com.example.gamename","pixelsRounding":false,"projectUuid":"d8300f43-dc93-4822-b7f4-a333798c7914","scaleMode":"linear","sizeOnStartupMode":"noChanges","templateSlug":"","version":"1.0.0","name":"Yodel_Ay_Hi_Score_Main_Build","description":"You are a yodeler. You are also not very good at it. The mountain stares.\nScream into your mic to jump. Sustain a note to float gracefully like the majestic alpine legend you absolutely are not. Go silent and fall like a disappointment. Rocks will fall on you. You will deserve it.\nReach the summit. Achieve glory. Disturb everyone within earshot.\n\n🎤 Microphone HIGLY RECOMMENDED. Headphones and dignity optional.\nMade with GDevelop. Powered entirely by your inability to carry a tune.\n\nHow to play:\n\n• Scream, yodel, or make any loud noise into your microphone to jump\n\n• Use arrow keys or on-screen controls to move left and right\n\n• Yodel your way to the summit using your microphone or use the spacebar if your neighbors are asleep.\n\n• Time it just right to get an extra BOOST UP!​\n\n• Collect flowers, mushrooms, and stars hidden across each level\n\n• Dodge falling rocks on your way up\n\n• Reach the top!\n\n• Playable by literally anyone who can make noise — toddlers included\n\n**Currently working on mobile controls\n\n\n\n🛠 Made with: GDevelop, Web Audio API, pixel art assets, and a lot of screaming.\n\n\n\nBest played with headphones off and volume up. Your neighbors will understand.\n\n\n\n🤖 A note on AI tools: AI was used in the development of this game, including AI-generated pixel art assets and coding assistance. All game design, level design, creative direction, and final implementation decisions were made by the developer.","author":" Syzygy Entertainment","windowWidth":800,"windowHeight":780,"latestCompilationDirectory":"C:\\Users\\madel\\Documents\\GitHub\\Syzygy Gaming\\Yodel-Ay-Hi-Score\\Yodel_1","maxFPS":60,"minFPS":20,"verticalSync":false,"platformSpecificAssets":{"android-icon-144":"","android-icon-192":"","android-icon-36":"","android-icon-48":"","android-icon-72":"","android-icon-96":"","android-windowSplashScreenAnimatedIcon":"","desktop-icon-512":"","ios-icon-100":"","ios-icon-1024":"","ios-icon-114":"","ios-icon-120":"","ios-icon-144":"","ios-icon-152":"","ios-icon-167":"","ios-icon-180":"","ios-icon-20":"","ios-icon-29":"","ios-icon-40":"","ios-icon-50":"","ios-icon-57":"","ios-icon-58":"","ios-icon-60":"","ios-icon-72":"","ios-icon-76":"","ios-icon-80":"","ios-icon-87":""},"loadingScreen":{"backgroundColor":0,"backgroundFadeInDuration":0.2,"backgroundImageResourceName":"","gdevelopLogoStyle":"light","logoAndProgressFadeInDuration":0.2,"logoAndProgressLogoFadeInDelay":0.0,"minDuration":1.5,"progressBarColor":16777215,"progressBarHeight":20.0,"progressBarMaxWidth":200.0,"progressBarMinWidth":40.0,"progressBarWidthPercent":30.0,"showGDevelopSplash":true,"showProgressBar":true},"watermark":{"placement":"bottom-left","showWatermark":true},"authorIds":["1BDlN3xUyLfciGjm44rBlw4Yaft1"],"authorUsernames":[],"categories":["platformer","game-jam-9"],"playableDevices":["keyboard"],"extensionProperties":[],"platforms":[{"name":"GDevelop JS platform"}],"currentPlatform":"GDevelop JS platform"},"resources":{"resources":[{"file":"assets/tiled_Grass.png","kind":"image","metadata":"","name":"tiled_Grass.png","smoothed":true,"userAdded":false,"origin":{"identifier":"https://asset-resources.gdevelop.io/public-resources/Breakable Physics/Background/f0fcdea023107dc7c4263d38d52d5f6f74a5b779887760a1580a613f7f4b2af0_tiled_Grass.png","name":"tiled_Grass.png"}},{"file":"assets/Background Mountain 1.png","kind":"image","metadata":"","name":"Background Mountain 1.png","smoothed":true,"userAdded":false,"origin":{"identifier":"htt